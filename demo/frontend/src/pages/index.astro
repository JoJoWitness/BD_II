---
import '../styles/global.css';

const apiUrl = 'http://localhost:8080';
---

<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Comunicaciones II</title>
</head>
<body>

<div class="container">
  <h1>Practica III, Comunicaciones II</h1>

  <section>
    <button id="get-btn">Mostrar frase</button>
    <div id="get-result"></div>
  </section>

  <section>
    <h2>Frases</h2>
    <table id="list-table">
      <thead>
        <tr><th>ID</th><th>Frase</th></tr>
      </thead>
      <tbody id="list"></tbody>
    </table>
  </section>

  <section>
    <h2>Agregar</h2>
    <form id="add-form">
      <input type="text" id="add-input" placeholder="Nueva frase" required />
      <button type="submit">Agregar</button>
    </form>
    <div id="add-result"></div>
  </section>

  <section>
    <h2>Eliminar</h2>
    <form id="del-form">
      <input type="number" id="del-input" placeholder="ID a eliminar" required min="1" />
      <button type="submit">Eliminar</button>
    </form>
    <div id="del-result"></div>
  </section>
</div>

<script define:vars={{ API_URL: apiUrl }}>
  const getBtn = document.getElementById('get-btn');
  const getResult = document.getElementById('get-result');
  const addForm = document.getElementById('add-form');
  const addInput = document.getElementById('add-input');
  const addResult = document.getElementById('add-result');
  const delForm = document.getElementById('del-form');
  const delInput = document.getElementById('del-input');
  const delResult = document.getElementById('del-result');
  const list = document.getElementById('list');

  async function call(method, path, body) {
    const opts = { method };
    if (body !== undefined) {
      opts.headers = { 'Content-Type': 'application/json' };
      opts.body = JSON.stringify(body);
    }
    const res = await fetch(API_URL + path, opts);
    const data = await res.json();
    if (!res.ok) throw new Error(data.error || 'HTTP ' + res.status);
    return data;
  }

  async function refreshList() {
    try {
      const data = await call('GET', '/phrases');
      list.innerHTML = '';
      if (!data.length) {
        list.innerHTML = '<tr class="empty"><td colspan="2">Sin frases</td></tr>';
        return;
      }
      for (const p of data) {
        const tr = document.createElement('tr');
        const tdId = document.createElement('td');
        const tdText = document.createElement('td');
        tdId.textContent = p.id;
        tdText.textContent = p.phrase;
        tr.append(tdId, tdText);
        list.appendChild(tr);
      }
    } catch (err) {
      list.innerHTML = '<tr class="empty"><td colspan="2">Error: ' + err.message + '</td></tr>';
    }
  }

  getBtn.addEventListener('click', async () => {
    try {
      const data = await call('GET', '/phrase');
      getResult.textContent = '#' + data.id + ' - ' + data.phrase;
    } catch (err) {
      getResult.textContent = 'Error: ' + err.message;
    }
  });

  addForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    try {
      const data = await call('POST', '/phrase', { phrase: addInput.value });
      addResult.textContent = 'Agregada: #' + data.id + ' - ' + data.phrase;
      addInput.value = '';
      refreshList();
    } catch (err) {
      addResult.textContent = 'Error: ' + err.message;
    }
  });

  delForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    try {
      const data = await call('DELETE', '/phrase?id=' + encodeURIComponent(delInput.value));
      delResult.textContent = 'Eliminada #' + data.deleted;
      delInput.value = '';
      refreshList();
    } catch (err) {
      delResult.textContent = 'Error: ' + err.message;
    }
  });

  refreshList();
</script>

</body>
</html>
